<UserControl x:Class="FileExplorer.Extension.PdfPreview.PdfViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxpdf="http://schemas.devexpress.com/winfx/2008/xaml/pdf"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:properties="clr-namespace:FileExplorer.Extension.PdfPreview.Properties"
             x:Name="CodeBehind" DataContext="{Binding ElementName=CodeBehind}">

    <DockPanel>
        <dxb:ToolBarControl DockPanel.Dock="Bottom" Padding="10" Background="Transparent" HorizontalAlignment="Center" AllowQuickCustomization="False">
            <dxb:BarButtonItem Padding="8" ToolTip="{x:Static properties:Resources.Search}" Glyph="{dx:SvgImageSource Size='16,16', Uri=Assets/Search.svg}" Command="{Binding ShowFindTextCommand, ElementName=pdfViewer}" />
            <dxb:BarButtonItem Padding="8" ToolTip="{x:Static properties:Resources.RotateLeft}" Glyph="{dx:SvgImageSource Size='16,16', Uri=Assets/RotateLeft.svg}" Command="{Binding CounterClockwiseRotateCommand, ElementName=pdfViewer}" />
            <dxb:BarButtonItem Padding="8" ToolTip="{x:Static properties:Resources.RotateRight}" Glyph="{dx:SvgImageSource Size='16,16', Uri=Assets/RotateRight.svg}" Command="{Binding ClockwiseRotateCommand, ElementName=pdfViewer}" />            
            <dxb:BarEditItem Margin="0,0,5,0" EditValue="{Binding CurrentPageNumber, Mode=TwoWay, ElementName=pdfViewer}">
                <dxb:BarEditItem.EditSettings>
                    <dxe:ButtonEditSettings AllowDefaultButton="False" TextBlock.TextAlignment="Center" MaskType="Numeric" Mask="######0;" MaskUseAsDisplayFormat="True">
                        <dxe:ButtonEditSettings.Buttons>
                            <dxe:ButtonInfo ToolTip="{x:Static properties:Resources.PreviousPage}" GlyphKind="Up" IsLeft="True" Command="{Binding PreviousPageCommand, ElementName=pdfViewer}" />
                            <dxe:ButtonInfo ToolTip="{x:Static properties:Resources.NextPage}" GlyphKind="Down" Command="{Binding NextPageCommand, ElementName=pdfViewer}" />
                        </dxe:ButtonEditSettings.Buttons>
                    </dxe:ButtonEditSettings>
                </dxb:BarEditItem.EditSettings>
            </dxb:BarEditItem>
            <dxb:BarItemSeparator />
            <dxb:BarButtonItem Padding="8" ToolTip="{x:Static properties:Resources.ZoomIn}" Glyph="{dx:SvgImageSource Size='16,16', Uri=Assets/ZoomIn.svg}" Command="{Binding ZoomInCommand, ElementName=pdfViewer}" />            
            <dxb:BarSubItem Padding="8" Content="{Binding ZoomFactor, Converter={dxmvvm:FormatStringConverter FormatString=P0}}">
                <dxb:BarItemSelector AllowEmptySelection="True" ItemLinksSource="{Binding ZoomLevels}" SelectedItem="{Binding ZoomFactor}">
                    <dxb:BarItemSelector.ItemTemplate>
                        <DataTemplate>
                            <ContentControl>
                                <dxb:BarCheckItem Content="{Binding Converter={dxmvvm:FormatStringConverter FormatString=P0}}" />
                            </ContentControl>
                        </DataTemplate>
                    </dxb:BarItemSelector.ItemTemplate>
                </dxb:BarItemSelector>
            </dxb:BarSubItem>
            <dxb:BarButtonItem Padding="8" ToolTip="{x:Static properties:Resources.ZoomOut}" Glyph="{dx:SvgImageSource Size='16,16', Uri=Assets/ZoomOut.svg}" Command="{Binding ZoomOutCommand, ElementName=pdfViewer}" />
        </dxb:ToolBarControl>
        <dxpdf:PdfViewerControl x:Name="pdfViewer" CommandBarStyle="None" ShowStartScreen="False" ZoomMode="PageLevel" HighlightSelectionColor="#7FFFD100"
                                DocumentSource="{Binding Document, Mode=TwoWay}" ZoomFactor="{Binding ZoomFactor, Mode=TwoWay}" Loaded="OnPdfViewerLoaded">
            <dxpdf:PdfViewerControl.CommentViewerSettings>
                <dxpdf:PdfCommentViewerSettings HideCommentViewer="True" />
            </dxpdf:PdfViewerControl.CommentViewerSettings>
            <dxpdf:PdfViewerControl.OutlinesViewerSettings>
                <dxpdf:PdfOutlinesViewerSettings HideOutlinesViewer="True" />
            </dxpdf:PdfViewerControl.OutlinesViewerSettings>
            <dxpdf:PdfViewerControl.ThumbnailsViewerSettings>
                <dxpdf:PdfThumbnailsViewerSettings HideThumbnailsViewer="True" />
            </dxpdf:PdfViewerControl.ThumbnailsViewerSettings>
            <dxpdf:PdfViewerControl.AttachmentsViewerSettings>
                <dxpdf:PdfAttachmentsViewerSettings HideAttachmentsViewer="True" />
            </dxpdf:PdfViewerControl.AttachmentsViewerSettings>
        </dxpdf:PdfViewerControl>
    </DockPanel>

</UserControl>
